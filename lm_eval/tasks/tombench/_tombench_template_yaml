# Shared config for every ToMBench task. Per-leaf: `task`, `description` (the verbatim
# system prompt), `dataset_kwargs` (language / try_times / fix_gold_typo) and the FULL
# `generation_kwargs` block -- `include:` does not deep-merge nested mappings.
custom_dataset: !function utils.load
test_split: train
output_type: generate_until
# The loader renders the user prompt (paper Table 20) once per shuffled repeat.
doc_to_text: "{{input_text}}"
doc_to_target: "{{target}}"   # logging only; scoring lives in process_results
process_results: !function utils.process_results
# Every metric is a ToMBench headline number. `process_results` emits the same per-run
# payload under all 57 names; each metric's custom aggregation majority-votes the 5
# shuffled repeats and then reads its own cell out of the roll-up.
metric_list:
  - {metric: acc, aggregation: !function utils.agg_acc, higher_is_better: true}
  - {metric: task_uot, aggregation: !function utils.agg_task_uot, higher_is_better: true}
