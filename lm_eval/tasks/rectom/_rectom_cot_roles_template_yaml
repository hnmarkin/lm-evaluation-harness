custom_dataset: !function utils.load
test_split: train
output_type: generate_until
doc_to_text: !function utils.doc_to_text_cot
doc_to_target: "{{answer}}"
process_results: !function utils.process_results_cot_by_role
generation_kwargs:
  until:
    - "</s>"
    - "<|im_end|>"
  do_sample: true
  temperature: 0.1
  max_gen_toks: 700
metric_list:
  - metric: acc
    aggregation: mean
    higher_is_better: true
  - metric: acc_rec
    aggregation: !function utils.agg_acc_rec
    higher_is_better: true
  - metric: acc_seeker
    aggregation: !function utils.agg_acc_seeker
    higher_is_better: true
metadata:
  version: 0

