custom_dataset: !function utils.load_xnegtom
test_split: train
output_type: generate_until
doc_to_text: !function utils.doc_to_text
doc_to_target: "{{target}}"
process_results: !function utils.process_results_xnegtom
generation_kwargs:
  # Qwen-2.5-7B-Instruct settings reported in XToM Appendix C.1.
  do_sample: true
  temperature: 0.5
  top_p: 0.7
  max_gen_toks: 256
  until:
    - "</s>"
    - "<|im_end|>"
