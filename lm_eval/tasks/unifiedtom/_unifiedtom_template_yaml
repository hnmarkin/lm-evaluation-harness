description: "You are a helpful assistant.\n\n"
custom_dataset: !function utils.load
test_split: train
output_type: generate_until
doc_to_text: "{{prompt}}"
doc_to_target: "{{target}}"
process_results: !function utils.process_results
generation_kwargs:
  until:
    - "</s>"
    - "<|im_end|>"
  do_sample: true
  temperature: 0.7
  max_gen_toks: 32
metric_list:
  - metric: acc
    aggregation: mean
    higher_is_better: true
metadata:
  version: 0

