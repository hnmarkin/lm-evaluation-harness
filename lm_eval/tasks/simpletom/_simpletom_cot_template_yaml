dataset_path: allenai/SimpleToM
test_split: test
output_type: generate_until
description: "You are a helpful assistant."
doc_to_text: !function utils.doc_to_text_cot
doc_to_target: answerKey
process_results: !function utils.process_results_cot
# No "\n\n" stop (CoT puts blank lines between steps, and truncating there would cut the trailing
# "the answer is" line), and max_gen_toks sized well past the paper's own 500. On Qwen/Qwen3-1.7B,
# total generated tokens peak at 1959 (largest seen across all runs); the previous 2048 cleared
# that by only 4.5%, which is not headroom. 4096 gives ~2.1x. This DOES affect scores; see README
# deviation 4.
generation_kwargs:
  until:
    - "</s>"
    - "<|im_end|>"
  do_sample: false
  temperature: 0.0
  max_gen_toks: 4096
metric_list:
  - metric: acc
    aggregation: mean
    higher_is_better: true
  # Repo-side diagnostic (basic_stats), not a paper number.
  - metric: na_frac
    aggregation: mean
    higher_is_better: false
  # Adapter-only tripwire for mid-`<think>` truncation. Should be 0.0 on a real run.
  - metric: truncated_think_frac
    aggregation: mean
    higher_is_better: false
metadata:
  version: 1
